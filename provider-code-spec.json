{
  "datasources": [
    {
      "name": "firewall_aliases",
      "schema": {
        "attributes": [
          {
            "name": "data",
            "list_nested": {
              "computed_optional_required": "computed",
              "nested_object": {
                "attributes": [
                  {
                    "name": "address",
                    "list": {
                      "computed_optional_required": "computed",
                      "element_type": {
                        "string": {}
                      },
                      "description": "Sets the host, network or port entries for the alias. When `type` is set to `host`, each\n                entry must be a valid IP address or FQDN. When `type` is set to `network`, each entry must be a valid\n                network CIDR or FQDN. When `type` is set to `port`, each entry must be a valid port or port range. You\n                may also specify an existing alias's `name` as an entry to created nested aliases.<br>"
                    }
                  },
                  {
                    "name": "descr",
                    "string": {
                      "computed_optional_required": "computed",
                      "description": "Sets a description to help specify the purpose or contents of the alias.<br>"
                    }
                  },
                  {
                    "name": "detail",
                    "list": {
                      "computed_optional_required": "computed",
                      "element_type": {
                        "string": {}
                      },
                      "description": "Sets descriptions for each alias `address`. Values must match the order of the `address` \n                value it relates to. For example, the first value specified here is the description for the first\n                value specified in the `address` field. This value cannot contain <br>"
                    }
                  },
                  {
                    "name": "name",
                    "string": {
                      "computed_optional_required": "computed",
                      "description": "Sets the name for the alias. This name must be unique from all other aliases.<br>"
                    }
                  },
                  {
                    "name": "type",
                    "string": {
                      "computed_optional_required": "computed",
                      "description": "Sets the type of alias this object will be. This directly impacts what values can be\n                specified in the `address` field.<br>"
                    }
                  }
                ]
              }
            }
          }
        ]
      }
    }
  ],
  "provider": {
    "name": "pfsense"
  },
