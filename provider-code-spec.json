    {
      "name": "firewall_rule",
      "schema": {
        "attributes": [
          {
            "name": "ackqueue",
            "string": {
              "computed_optional_required": "computed_optional",
              "description": "The name of the traffic shaper queue to assume as the ACK queue for ACK traffic matching this rule.<br>"
            }
          },
          {
            "name": "associated_rule_id",
            "string": {
              "computed_optional_required": "computed_optional",
              "description": "The internal rule ID for the NAT rule associated with this rule.<br>",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
                    ],
                    "schema_definition": "stringvalidator.LengthBetween(0, 1024)"
                  }
                }
              ]
            }
          },
          {
            "name": "created_by",
            "string": {
              "computed_optional_required": "computed_optional",
              "default": {
                "static": "@unknown IP (API)"
              },
              "description": "The username and IP of the user who originally created this firewall rule.<br>",
              "validators": [
                {
                  "custom": {
                    "imports": [
                      {
                        "path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
                      }
